{
    "version": 6,
    "configurePresets": [
        {
            "name": "mixin_ConfigBase",
            "description": "Common base settings for all configurations",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "OSC_VENV": "${sourceDir}/.venv"
            }
        },
        {
            "name": "mixin_RapidLinuxLinking",
            "hidden": true,
            "description": "Mixin to enable the mold linker, thin archives, and split dwarf files for faster linking (useful for development)",
            "cacheVariables": {
                "CMAKE_EXE_LINKER_FLAGS": "-fuse-ld=mold",
                "CMAKE_SHARED_LINKER_FLAGS": "-fuse-ld=mold",
                "CMAKE_MODULE_LINKER_FLAGS": "-fuse-ld=mold",
                "CMAKE_CXX_ARCHIVE_CREATE": "<CMAKE_AR> srT <TARGET> <LINK_FLAGS> <OBJECTS>",
                "CMAKE_CXX_FLAGS": "-gsplit-dwarf"
            }
        },
        {
            "name": "mixin_InlinedDevelopment",
            "hidden": true,
            "description": "Mixin that enables inlining the third_party build into this build (useful for development)",
            "cacheVariables": {
                "CMAKE_POSITION_INDEPENDENT_CODE": "ON",
                "OSC_BUILD_DOCS": "ON",
                "OSC_BUILD_OSCAR_INLINE": "ON",
                "OSC_BUILD_OPYNSIM_INLINE": "ON",
                "OPYN_USE_STRICT_COMPILER_FLAGS": "ON",
                "OPYN_PACKAGE": "OFF",
                "OPYN_BUILD_DOCS": "ON",
                "OPYN_BUILD_PYTHON_BINDINGS": "ON",
                "OPYN_BUILD_TESTING": "ON",
                "OPYN_VENV": "${sourceDir}/.venv",
                "OPYN_BUILD_OPYNSIM_DEBUGGER": "ON",
                "OPYN_STRICT_ABI_CHECKS": "OFF"
            }
        },
        {
            "name": "Development",
            "inherits": ["mixin_ConfigBase"],
            "binaryDir": "${sourceDir}/build/Development",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_PREFIX_PATH": "${sourceDir}/build/third_party/Development/install",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/Development/install",
                "OSC_USE_STRICT_COMPILER_FLAGS": "ON"
            }
        },
        {
            "name": "Development-Inlined",
            "inherits": ["Development", "mixin_InlinedDevelopment"],
            "binaryDir": "${sourceDir}/build/Development-Inlined",
            "cacheVariables": {
                "CMAKE_PREFIX_PATH": "${sourceDir}/build/third_party/Development-Inlined/install",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/Development-Inlined/install"
            }
        },
        {
            "name": "Development-Inlined-RapidLinuxLinking",
            "inherits": ["Development-Inlined", "mixin_RapidLinuxLinking"]
        },
        {
            "name": "ErrorCheck",
            "inherits": ["mixin_ConfigBase"],
            "binaryDir": "${sourceDir}/build/ErrorCheck",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_PREFIX_PATH": "${sourceDir}/build/third_party/ErrorCheck/install",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/ErrorCheck/install",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_C_FLAGS": "-fsanitize=address,undefined -fno-sanitize-recover=all",
                "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-sanitize-recover=all",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined -rdynamic",
                "CMAKE_CXX_CLANG_TIDY": "clang-tidy",
                "OSC_USE_STRICT_COMPILER_FLAGS": "ON"
            }
        },
        {
            "name": "ErrorCheck-Inlined",
            "inherits": ["ErrorCheck", "mixin_InlinedDevelopment"],
            "binaryDir": "${sourceDir}/build/ErrorCheck-Inlined",
            "cacheVariables": {
                "CMAKE_PREFIX_PATH": "${sourceDir}/build/third_party/ErrorCheck-Inlined/install",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/ErrorCheck-Inlined/install",
                "OPYN_BUILD_PYTHON_TESTING": "OFF",
                "OPYN_GENERATE_STUBS": "OFF"
            }
        },
        {
            "name": "ErrorCheck-Inlined-RapidLinuxLinking",
            "inherits": ["ErrorCheck-Inlined", "mixin_RapidLinuxLinking"]
        },
        {
            "name": "RelWithDebInfo",
            "inherits": ["mixin_ConfigBase"],
            "binaryDir": "${sourceDir}/build/RelWithDebInfo",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_PREFIX_PATH": "${sourceDir}/build/third_party/RelWithDebInfo/install",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/RelWithDebInfo/install"
            }
        },
        {
            "name": "RelWithDebInfo-Inlined",
            "inherits": ["RelWithDebInfo", "mixin_InlinedDevelopment"],
            "binaryDir": "${sourceDir}/build/RelWithDebInfo-Inlined",
            "cacheVariables": {
                "CMAKE_PREFIX_PATH": "${sourceDir}/build/third_party/RelWithDebInfo-Inlined/install",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/RelWithDebInfo-Inlined/install"
            }
        },
        {
            "name": "RelWithDebInfo-Inlined-RapidLinuxLinking",
            "inherits": ["RelWithDebInfo-Inlined", "mixin_RapidLinuxLinking"]
        },
        {
            "name": "Release-Linux-amd64",
            "inherits": ["mixin_ConfigBase"],
            "binaryDir": "${sourceDir}/build/Release-Linux-amd64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_PREFIX_PATH": "${sourceDir}/build/third_party/Release-Linux-amd64/install",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/Release-Linux-amd64/install",
                "CMAKE_EXE_LINKER_FLAGS": "-static-libstdc++ -static-libgcc",
                "CMAKE_SHARED_LINKER_FLAGS": "-static-libstdc++ -static-libgcc",
                "OSC_STRICT_ABI_CHECKS": "ON"
            }
        },
        {
            "name": "Release-MacOS-amd64",
            "inherits": ["mixin_ConfigBase"],
            "binaryDir": "${sourceDir}/build/Release-MacOS-amd64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_PREFIX_PATH": "${sourceDir}/build/third_party/Release-MacOS-amd64/install",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/Release-MacOS-amd64/install",
                "CMAKE_OSX_ARCHITECTURES": "x86_64",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "14.5",
                "OSC_STRICT_ABI_CHECKS": "ON"
            }
        },
        {
            "name": "Release-MacOS-arm64",
            "inherits": ["mixin_ConfigBase"],
            "binaryDir": "${sourceDir}/build/Release-MacOS-arm64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_PREFIX_PATH": "${sourceDir}/build/third_party/Release-MacOS-arm64/install",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/Release-MacOS-arm64/install",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "14.5",
                "OSC_STRICT_ABI_CHECKS": "ON"
            }
        },
        {
            "name": "Release-Windows-amd64",
            "inherits": ["mixin_ConfigBase"],
            "binaryDir": "${sourceDir}/build/Release-Windows-amd64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_PREFIX_PATH": "${sourceDir}/build/third_party/Release-Windows-amd64/install",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/Release-Windows-amd64/install",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded",
                "OSC_STRICT_ABI_CHECKS": "ON"
            }
        },
        {
            "name": "Release-Windows-amd64-Codesigned",
            "inherits": ["Release-Windows-amd64"],
            "cacheVariables": {
                "OSC_CODESIGN_ENABLED": "ON"
            }
        }
    ],
    "buildPresets": [
        { "name": "Development",                       "configurePreset": "Development"                      },
        { "name": "Development-Inlined",               "configurePreset": "Development-Inlined"              },
        { "name": "ErrorCheck",                        "configurePreset": "ErrorCheck"                       },
        { "name": "ErrorCheck-Inlined",                "configurePreset": "ErrorCheck-Inlined"               },
        { "name": "RelWithDebInfo",                    "configurePreset": "RelWithDebInfo"                   },
        { "name": "RelWithDebInfo-Inlined",            "configurePreset": "RelWithDebInfo-Inlined"           },
        { "name": "Release-Linux-amd64",               "configurePreset": "Release-Linux-amd64"              },
        { "name": "Release-MacOS-amd64",               "configurePreset": "Release-MacOS-amd64"              },
        { "name": "Release-MacOS-arm64",               "configurePreset": "Release-MacOS-arm64"              },
        { "name": "Release-Windows-amd64",             "configurePreset": "Release-Windows-amd64"            },
        { "name": "Release-Windows-amd64-Codesigned",  "configurePreset": "Release-Windows-amd64-Codesigned" }
    ],
    "testPresets": [
        {
            "name": "mixin_TestBase",
            "description": "Mixin for common test options",
            "hidden": true,
            "output": {"outputOnFailure": true},
            "execution": {"noTestsAction": "error"},
            "filter": {
                "exclude": {
                    "name": "$env{OSC_TEST_EXCLUDE_FILTER}"
                }
            }
        },
        {
            "name": "mixin_TestAsan",
            "description": "Mixin to add necessary ASAN/UBSAN/LSAN flags to the test suite",
            "hidden": true,
            "environment": {
                "ASAN_OPTIONS": "abort_on_error=1:strict_string_checks=true:malloc_context_size=30:check_initialization_order=true:detect_stack_use_after_return=true:strict_init_order=true:detect_invalid_pointer_pairs=2",
                "UBSAN_OPTIONS": "abort_on_error=1:print_stacktrace=1:print_summary=1:suppressions=${sourceDir}/scripts/suppressions_ubsan.supp",
                "LSAN_OPTIONS": "suppressions=${sourceDir}/scripts/suppressions_lsan.supp",
                "LIBGL_ALWAYS_SOFTWARE": "1"
            }
        },
        {
            "name": "Development",
            "configurePreset": "Development",
            "inherits": ["mixin_TestBase"]
        },
        {
            "name": "Development-Inlined",
            "configurePreset": "Development-Inlined",
            "inherits": ["Development"]
        },
        {
            "name": "ErrorCheck",
            "configurePreset": "ErrorCheck",
            "inherits": ["mixin_TestBase", "mixin_TestAsan"]
        },
        {
            "name": "ErrorCheck-Inlined",
            "configurePreset": "ErrorCheck-Inlined",
            "inherits": ["ErrorCheck"]
        },
        {
            "name": "RelWithDebInfo",
            "configurePreset": "RelWithDebInfo",
            "inherits": ["mixin_TestBase"]
        },
        {
            "name": "RelWithDebInfo-Inlined",
            "configurePreset": "RelWithDebInfo-Inlined",
            "inherits": ["RelWithDebInfo"]
        },
        {
            "name": "Release-Linux-amd64",
            "configurePreset": "Release-Linux-amd64",
            "inherits": ["mixin_TestBase"]
        },
        {
            "name": "Release-MacOS-amd64",
            "configurePreset": "Release-MacOS-amd64",
            "inherits": ["mixin_TestBase"]
        },
        {
            "name": "Release-MacOS-arm64",
            "configurePreset": "Release-MacOS-arm64",
            "inherits": ["mixin_TestBase"]
        },
        {
            "name": "Release-Windows-amd64",
            "configurePreset": "Release-Windows-amd64",
            "inherits": ["mixin_TestBase"]
        },
        {
            "name": "Release-Windows-amd64-Codesigned",
            "configurePreset": "Release-Windows-amd64-Codesigned",
            "inherits": ["mixin_TestBase"]
        }
    ],
    "packagePresets": [
        { "name": "Release-Linux-amd64",              "configurePreset": "Release-Linux-amd64"   },
        { "name": "Release-MacOS-amd64",              "configurePreset": "Release-MacOS-amd64"   },
        { "name": "Release-MacOS-arm64",              "configurePreset": "Release-MacOS-arm64"   },
        { "name": "Release-Windows-amd64",            "configurePreset": "Release-Windows-amd64" },
        { "name": "Release-Windows-amd64-Codesigned", "configurePreset": "Release-Windows-amd64-Codesigned" }
    ],
    "workflowPresets": [
        {
            "name": "Development",
            "steps": [
                { "type": "configure", "name": "Development" },
                { "type": "build",     "name": "Development" }
            ]
        },
        {
            "name": "Development-Inlined",
            "steps": [
                { "type": "configure", "name": "Development-Inlined" },
                { "type": "build",     "name": "Development-Inlined" }
            ]
        },
        {
            "name": "ErrorCheck",
            "steps": [
                { "type": "configure", "name": "ErrorCheck" },
                { "type": "build",     "name": "ErrorCheck" },
                { "type": "test",      "name": "ErrorCheck" }
            ]
        },
        {
            "name": "ErrorCheck-Inlined",
            "steps": [
                { "type": "configure", "name": "ErrorCheck-Inlined" },
                { "type": "build",     "name": "ErrorCheck-Inlined" },
                { "type": "test",      "name": "ErrorCheck-Inlined" }
            ]
        },
        {
            "name": "RelWithDebInfo",
            "steps": [
                { "type": "configure", "name": "RelWithDebInfo" },
                { "type": "build",     "name": "RelWithDebInfo" }
            ]
        },
        {
            "name": "RelWithDebInfo-Inlined",
            "steps": [
                { "type": "configure", "name": "RelWithDebInfo-Inlined" },
                { "type": "build",     "name": "RelWithDebInfo-Inlined" }
            ]
        },
        {
            "name": "Release-Linux-amd64",
            "steps": [
                { "type": "configure", "name": "Release-Linux-amd64" },
                { "type": "build",     "name": "Release-Linux-amd64" },
                { "type": "test",      "name": "Release-Linux-amd64" },
                { "type": "package",   "name": "Release-Linux-amd64" }
            ]
        },
        {
            "name": "Release-MacOS-amd64",
            "steps": [
                { "type": "configure", "name": "Release-MacOS-amd64" },
                { "type": "build",     "name": "Release-MacOS-amd64" },
                { "type": "test",      "name": "Release-MacOS-amd64" },
                { "type": "package",   "name": "Release-MacOS-amd64" }
            ]
        },
        {
            "name": "Release-MacOS-arm64",
            "steps": [
                { "type": "configure", "name": "Release-MacOS-arm64" },
                { "type": "build",     "name": "Release-MacOS-arm64" },
                { "type": "test",      "name": "Release-MacOS-arm64" },
                { "type": "package",   "name": "Release-MacOS-arm64" }
            ]
        },
        {
            "name": "Release-Windows-amd64",
            "steps": [
                { "type": "configure", "name": "Release-Windows-amd64" },
                { "type": "build",     "name": "Release-Windows-amd64" },
                { "type": "test",      "name": "Release-Windows-amd64" },
                { "type": "package",   "name": "Release-Windows-amd64" }
            ]
        },
        {
            "name": "Release-Windows-amd64-Codesigned",
            "steps": [
                { "type": "configure", "name": "Release-Windows-amd64-Codesigned" },
                { "type": "build",     "name": "Release-Windows-amd64-Codesigned" },
                { "type": "test",      "name": "Release-Windows-amd64-Codesigned" },
                { "type": "package",   "name": "Release-Windows-amd64-Codesigned" }
            ]
        }
    ]
}
