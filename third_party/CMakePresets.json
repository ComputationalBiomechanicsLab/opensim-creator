{
    "version": 6,
    "configurePresets": [
        {
            "name": "mixin_ConfigBase",
            "description": "Common base settings for all configurations",
            "hidden": true,
            "generator": "Ninja"
        },
        {
            "name": "mixin_InlinedDevelopment",
            "hidden": true,
            "description": "Enables inlining the OPynSim build into this build (useful for development)",
            "cacheVariables": {
                "CMAKE_POSITION_INDEPENDENT_CODE": "ON",
                "OSCDEPS_BUILD_OPYNSIM_DEPS": "ON",
                "OSCDEPS_BUILD_OSCAR": "OFF",
                "OSCDEPS_BUILD_OPYNSIM": "OFF"
            }
        },
        {
            "name": "Development",
            "inherits": ["mixin_ConfigBase"],
            "binaryDir": "${sourceDir}/../build/third_party/Development",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/../build/third_party/Development/install"
            }
        },
        {
            "name": "Development-Inlined",
            "inherits": ["Development", "mixin_InlinedDevelopment"],
            "binaryDir": "${sourceDir}/../build/third_party/Development-Inlined",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/../build/third_party/Development-Inlined/install"
            }
        },
        {
            "name": "ErrorCheck",
            "inherits": ["mixin_ConfigBase"],
            "binaryDir": "${sourceDir}/../build/third_party/ErrorCheck",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/../build/third_party/ErrorCheck/install",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
            }
        },
        {
            "name": "ErrorCheck-Inlined",
            "inherits": ["ErrorCheck", "mixin_InlinedDevelopment"],
            "binaryDir": "${sourceDir}/../build/third_party/ErrorCheck-Inlined",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/../build/third_party/ErrorCheck-Inlined/install"
            }
        },
        {
            "name": "RelWithDebInfo",
            "inherits": ["mixin_ConfigBase"],
            "binaryDir": "${sourceDir}/../build/third_party/RelWithDebInfo",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/../build/third_party/RelWithDebInfo/install"
            }
        },
        {
            "name": "RelWithDebInfo-Inlined",
            "inherits": ["RelWithDebInfo", "mixin_InlinedDevelopment"],
            "binaryDir": "${sourceDir}/../build/third_party/RelWithDebInfo-Inlined",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/../build/third_party/RelWithDebInfo-Inlined/install"
            }
        },
        {
            "name": "Release-Linux-amd64",
            "inherits": ["mixin_ConfigBase"],
            "binaryDir": "${sourceDir}/../build/third_party/Release-Linux-amd64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/../build/third_party/Release-Linux-amd64/install",
                "CMAKE_EXE_LINKER_FLAGS": "-static-libstdc++ -static-libgcc",
                "CMAKE_SHARED_LINKER_FLAGS": "-static-libstdc++ -static-libgcc",
                "CMAKE_C_FLAGS": "-march=x86-64-v3",
                "CMAKE_CXX_FLAGS": "-march=x86-64-v3"
            }
        },
        {
            "name": "Release-MacOS-arm64",
            "inherits": ["mixin_ConfigBase"],
            "binaryDir": "${sourceDir}/../build/third_party/Release-MacOS-arm64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/../build/third_party/Release-MacOS-arm64/install",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "14.5",
                "CMAKE_CXX_FLAGS": "-Wunguarded-availability -Werror=unguarded-availability -Werror=unguarded-availability-new"
            }
        },
        {
            "name": "Release-Windows-amd64",
            "inherits": ["mixin_ConfigBase"],
            "binaryDir": "${sourceDir}/../build/third_party/Release-Windows-amd64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/../build/third_party/Release-Windows-amd64/install",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded",
                "CMAKE_C_FLAGS": "/arch:AVX2",
                "CMAKE_CXX_FLAGS": "/arch:AVX2 /EHsc"
            }
        }
    ],
    "buildPresets": [
        { "name": "Development",            "configurePreset": "Development"            },
        { "name": "Development-Inlined",    "configurePreset": "Development-Inlined"    },
        { "name": "ErrorCheck",             "configurePreset": "ErrorCheck"             },
        { "name": "ErrorCheck-Inlined",     "configurePreset": "ErrorCheck-Inlined"     },
        { "name": "RelWithDebInfo",         "configurePreset": "RelWithDebInfo"         },
        { "name": "RelWithDebInfo-Inlined", "configurePreset": "RelWithDebInfo-Inlined" },
        { "name": "Release-Linux-amd64",    "configurePreset": "Release-Linux-amd64"    },
        { "name": "Release-MacOS-arm64",    "configurePreset": "Release-MacOS-arm64"    },
        { "name": "Release-Windows-amd64",  "configurePreset": "Release-Windows-amd64"  }
    ],
    "workflowPresets": [
        {
            "name": "Development",
            "steps": [
                { "type": "configure", "name": "Development" },
                { "type": "build",     "name": "Development" }
            ]
        },
        {
            "name": "Development-Inlined",
            "steps": [
                { "type": "configure", "name": "Development-Inlined" },
                { "type": "build",     "name": "Development-Inlined" }
            ]
        },
        {
            "name": "ErrorCheck",
            "steps": [
                { "type": "configure", "name": "ErrorCheck" },
                { "type": "build",     "name": "ErrorCheck" }
            ]
        },
        {
            "name": "ErrorCheck-Inlined",
            "steps": [
                { "type": "configure", "name": "ErrorCheck-Inlined" },
                { "type": "build",     "name": "ErrorCheck-Inlined" }
            ]
        },
        {
            "name": "RelWithDebInfo",
            "steps": [
                { "type": "configure", "name": "RelWithDebInfo" },
                { "type": "build",     "name": "RelWithDebInfo" }
            ]
        },
        {
            "name": "RelWithDebInfo-Inlined",
            "steps": [
                { "type": "configure", "name": "RelWithDebInfo-Inlined" },
                { "type": "build",     "name": "RelWithDebInfo-Inlined" }
            ]
        },
        {
            "name": "Release-Linux-amd64",
            "steps": [
                { "type": "configure", "name": "Release-Linux-amd64" },
                { "type": "build",     "name": "Release-Linux-amd64" }
            ]
        },
        {
            "name": "Release-MacOS-arm64",
            "steps": [
                { "type": "configure", "name": "Release-MacOS-arm64" },
                { "type": "build",     "name": "Release-MacOS-arm64" }
            ]
        },
        {
            "name": "Release-Windows-amd64",
            "steps": [
                { "type": "configure", "name": "Release-Windows-amd64" },
                { "type": "build",     "name": "Release-Windows-amd64" }
            ]
        }
    ]
}
