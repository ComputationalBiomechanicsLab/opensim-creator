This patches the implicit `finalizeFromProperties` call out of
OpenSim::Model's constructors.

This is because OpenSim Creator and OPynSim assume finalization
occurs after construction, so we want the caller to control when
it happens, rather than these constructors adsorbing it.

---

diff --git a/OpenSim/Simulation/Model/Model.cpp b/OpenSim/Simulation/Model/Model.cpp
index 5654bdeb2..83cee3e5a 100644
--- a/OpenSim/Simulation/Model/Model.cpp
+++ b/OpenSim/Simulation/Model/Model.cpp
@@ -192,7 +192,6 @@ Model::Model() : ModelComponent(),
 {
     constructProperties();
     setNull();
-    finalizeFromProperties();
 }
 //_____________________________________________________________________________
 /*
@@ -219,17 +218,6 @@ Model::Model(const string &aFileName) :
 
     _fileName = aFileName;
     log_info("Loaded model {} from file {}", getName(), getInputFileName());
-
-    try {
-        finalizeFromProperties();
-    }
-    catch(const InvalidPropertyValue& err) {
-        log_error("Model was unable to finalizeFromProperties."
-                  "Update the model file and reload OR update the property and "
-                  "call finalizeFromProperties() on the model."
-                  "(details: {}).",
-                err.what());
-    }
 }
 
 Model* Model::clone() const
@@ -237,17 +225,6 @@ Model* Model::clone() const
     // Invoke default copy constructor.
     Model* clone = new Model(*this);
 
-    try {
-        clone->finalizeFromProperties();
-    }
-    catch (const InvalidPropertyValue& err) {
-        log_error(
-                "clone() was unable to finalizeFromProperties."
-                "Update the model and call clone() again OR update the clone's "
-                " property and call finalizeFromProperties() on it. (details: {}).",
-                err.what());
-    }
-
     return clone;
 }
 
